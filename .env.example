# Runtime Postgres (Neon or Supabase). Tests use in-process pglite instead.
DATABASE_URL=postgres://user:password@host:5432/rollvault

# Public origin used for absolute URLs in sitemap.xml / robots.txt.
# Set this to the production domain before launch.
NEXT_PUBLIC_SITE_URL=https://rollvault.net

# Anthropic API key for assisted ingestion (Phase D). Required only to run live
# extraction; the review/commit pipeline works without it.
ANTHROPIC_API_KEY=sk-ant-...
# Optional override for the extraction model (default claude-opus-4-8).
INGEST_MODEL=claude-opus-4-8
